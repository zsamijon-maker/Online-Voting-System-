# Local development
VITE_API_URL=http://localhost:5000

# Optional: force absolute post-login redirect (leave blank for '/dashboard' on same origin)
# VITE_POST_LOGIN_REDIRECT_URL=https://online-voting-system-fejgnxjwk-zsamijon-makers-projects.vercel.app/dashboard

# Optional: explicit OAuth callback URL (recommended when testing localhost with Google OAuth)
# VITE_OAUTH_REDIRECT_URL=http://localhost:5173/auth/callback

# Optional safety override. Defaults to false.
# Keep this unset unless you intentionally need cross-origin post-login redirects.
# VITE_ALLOW_CROSS_ORIGIN_REDIRECT=false

# Supabase public keys
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
