# Environment Variables for Secure School Voting System Backend

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Anon key is used for client-side/public operations (get from Supabase dashboard > API)
SUPABASE_ANON_KEY=your-anon-key-here


# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── CORS ─────────────────────────────────────────────────
# Primary variable: comma-separated list of FULLY-QUALIFIED allowed origins.
# Example for production: ALLOWED_ORIGINS=https://voting.myschool.edu
# Example for multiple:   ALLOWED_ORIGINS=https://voting.myschool.edu,https://admin.myschool.edu
ALLOWED_ORIGINS=http://localhost:5173
# Legacy fallback (still works if ALLOWED_ORIGINS is not set)
FRONTEND_URL=http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────
# Max number of requests per window per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Security ─────────────────────────────────────────────
# Salt rounds for bcrypt (if used for extra hashing)
BCRYPT_ROUNDS=12
